pipeline {
  agent {
    kubernetes {
      yaml """
apiVersion: v1
kind: Pod
metadata:
  labels:
    some-label: jenkins-kaniko
spec:
  serviceAccountName: jenkins-sa

  containers:
    - name: kaniko
      image: gcr.io/kaniko-project/executor:v1.23.2-debug
      imagePullPolicy: IfNotPresent
      command:
        - sleep
      args:
        - 99d

      resources:
        requests:
          cpu: "100m"
          memory: "256Mi"
        limits:
          cpu: "500m"
          memory: "768Mi"

      env:
        - name: AWS_SDK_LOAD_CONFIG
          value: "true"

        - name: AWS_EC2_METADATA_DISABLED
          value: "true"

    - name: git
      image: alpine/git:2.47.2
      imagePullPolicy: IfNotPresent
      command:
        - sleep
      args:
        - 99d

      resources:
        requests:
          cpu: "50m"
          memory: "64Mi"
        limits:
          cpu: "200m"
          memory: "128Mi"
"""
    }
  }

  options {
    skipDefaultCheckout(true)
    disableConcurrentBuilds()
  }

  environment {
    ECR_REGISTRY = "128066560844.dkr.ecr.eu-central-1.amazonaws.com"
    IMAGE_NAME   = "lesson-7-ecr"
    IMAGE_TAG    = "v1.0.${BUILD_NUMBER}"

    GITOPS_REPO   = "github.com/slonic32/my-microservice-project.git"
    GITOPS_VALUES = "Progect/charts/django-app/values.yaml"

    COMMIT_EMAIL = "jenkins@localhost"
    COMMIT_NAME  = "jenkins"

    SKIP_PIPELINE = "false"
  }

  stages {
    stage('Checkout') {
      steps {
        container('git') {
          checkout scm
        }
      }
    }

    stage('Check Commit') {
      steps {
        container('git') {
          script {
            env.SKIP_PIPELINE = sh(
              script: '''
                if git log -1 --pretty=%B | grep -q '\\[jenkins\\]'; then
                  echo "true"
                else
                  echo "false"
                fi
              ''',
              returnStdout: true
            ).trim()

            if (env.SKIP_PIPELINE == "true") {
              echo "Jenkins commit detected. Image build will be skipped."
            }
          }
        }
      }
    }

    stage('Build & Push Docker Image') {
      when {
        expression {
          env.SKIP_PIPELINE != "true"
        }
      }

      steps {
        container('kaniko') {
          sh '''
            /kaniko/executor \
              --context "${WORKSPACE}/django" \
              --dockerfile "${WORKSPACE}/django/Dockerfile" \
              --destination "${ECR_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}" \
              --cache=true
          '''
        }
      }
    }

    stage('Update Chart Tag in Git') {
      when {
        expression {
          env.SKIP_PIPELINE != "true"
        }
      }

      steps {
        container('git') {
          withCredentials([
            usernamePassword(
              credentialsId: 'github-token',
              usernameVariable: 'GIT_USERNAME',
              passwordVariable: 'GIT_PAT'
            )
          ]) {
            sh '''
              rm -rf gitops

              git clone \
                --branch main \
                --single-branch \
                "https://${GIT_USERNAME}:${GIT_PAT}@${GITOPS_REPO}" \
                gitops

              cd gitops

              sed -i \
                "s|^[[:space:]]*tag:.*|  tag: \\"${IMAGE_TAG}\\"|" \
                "${GITOPS_VALUES}"

              git config user.email "${COMMIT_EMAIL}"
              git config user.name "${COMMIT_NAME}"

              git add "${GITOPS_VALUES}"

              if git diff --cached --quiet; then
                echo "No changes to commit"
                exit 0
              fi

              git commit \
                -m "Update image tag to ${IMAGE_TAG} [jenkins]"

              git push origin main
            '''
          }
        }
      }
    }
  }

  post {
    success {
      script {
        if (env.SKIP_PIPELINE == "true") {
          echo "Jenkins commit was detected. Pipeline was skipped."
        } else {
          echo "Image ${ECR_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG} was published"
          echo "Helm values were updated in ${GITOPS_REPO}"
        }
      }
    }

    failure {
      echo "Pipeline failed. Check the stage logs."
    }

    cleanup {
      cleanWs(
        deleteDirs: true,
        disableDeferredWipeout: true
      )
    }
  }
}